# Copie este arquivo para ".env" e preencha com os dados do seu Postgres.
# server.js/db.js leem DATABASE_URL automaticamente (via variável de ambiente,
# não é lido diretamente dos arquivos .env — use algo como "dotenv" ou exporte
# a variável no seu processo/serviço de deploy).

# Exemplo local:
# DATABASE_URL=postgres://usuario:senha@localhost:5432/prisma

# Exemplo Supabase/Neon/RDS (geralmente exigem SSL):
DATABASE_URL=postgres://usuario:senha@host:5432/nome_do_banco

# Defina como "false" apenas se o seu Postgres NÃO usar SSL (ex: local sem TLS).
# PGSSL=false

PORT=3000
